def clamp(n: int, lo: int, hi: int) -> int:
    return lo if n < lo else hi if n > hi else n


def safe_filename(s: str) -> str:
    s = (s or "").strip()
    s = re.sub(r"[\/\\\0]+", "-", s)
    s = re.sub(r"[\:\*\?\"\<\>\|]+", "", s)
    s = re.sub(r"\s+", " ", s)
    return s or "_"


def year_norm(y: str) -> str:
    y = (y or "").strip()
