def _resolve_config_dir() -> str:
    import platform
    if platform.system() == "Windows":
        app_data = os.environ.get("APPDATA") or os.path.join(os.path.expanduser("~"), "AppData", "Roaming")
        xdg_cfg = os.path.join(app_data, "mctui")
    else:
        xdg_base = os.environ.get("XDG_CONFIG_HOME", os.path.join(os.path.expanduser("~"), ".config"))
        xdg_cfg = os.path.join(xdg_base, "mctui")

    if os.path.isdir(xdg_cfg):
        return xdg_cfg

    script_dir = os.path.dirname(os.path.abspath(__file__))
    if os.access(script_dir, os.W_OK):
        return script_dir

    return xdg_cfg

