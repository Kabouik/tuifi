    def _draw_tabs(self, y: int, x: int, w: int) -> None:
        order = (1, 2, 3, 4, 5, 6, 7, 8, 9)
        s = "  ".join([TAB_NAMES[i] for i in order])[:max(0, w - 1)]
        self.stdscr.addstr(y, x, s, self.C(4))
